# ── Database (PostgreSQL) ─────────────────────────────────────────────
# Local Docker:  docker compose up -d
DATABASE_URL="postgresql://ats:ats@localhost:5432/ats"

# Cloud (Neon) — use the *pooler* host for the app:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
# DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
# Do NOT use channel_binding=require — it breaks Prisma on Windows.

# ── Auth (recruiter login) ────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-random-32-char-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Default recruiter (created by npm run db:seed)
RECRUITER_EMAIL="recruiter@ats.local"
RECRUITER_PASSWORD="recruiter123"
RECRUITER_NAME="Recruiter"

# ── Gemini LLM ────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash-lite"

# Optional fallbacks if primary model hits quota:
# GEMINI_FALLBACK_MODELS="gemini-2.0-flash-lite,gemini-1.5-flash"

# ── Recruitment automations (email workflows) ─────────────────────────
# Resend (same as sendemail.js) — required for real pipeline emails
RESEND_API_KEY="re_..."
EMAIL_FROM="Your Name <onboarding@resend.dev>"
COMPANY_NAME="Your Company"
SCHEDULING_URL="https://cal.com/your-team/interview"

# Cron auth for /api/cron/workflows (hourly follow-ups on Vercel)
CRON_SECRET="generate-a-random-secret-for-cron"
